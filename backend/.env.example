# Port d'écoute du serveur backend
PORT=5000

# URI de connexion à la base de données MongoDB (Atlas ou Local)
MONGO_URI=mongodb://localhost:27017/jardinMajorelle

# Clé secrète pour signer les jetons d'accès JSON Web Token (JWT)
JWT_SECRET=votre_secret_jwt_ici

# Configuration du stockage d'images sur AWS S3
AWS_REGION=eu-west-3
AWS_ACCESS_KEY=votre_cle_aws_access_key
AWS_SECRET_KEY=votre_cle_aws_secret_key
AWS_BUCKET_NAME=nom_de_votre_bucket_s3
